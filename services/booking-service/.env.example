# ===== Booking Service =====

# Server
SERVER_PORT=8080
GRPC_PORT=50051
GIN_MODE=debug

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=booking_db
DB_SSLMODE=disable

# Database Cleanup Configuration
CLEANUP_INTERVAL_MINUTES=60
CLEANUP_RETENTION_DAYS=30

