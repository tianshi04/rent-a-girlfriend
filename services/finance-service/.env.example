# ===== Finance Service =====

# Server ports
SERVER_PORT=8080
GRPC_PORT=50051
APP_ENV=development

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=finance_admin
DB_PASSWORD=super_secure_password
DB_NAME=finance_service
DB_SSLMODE=disable

# Kafka (Message Broker)
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC_FINANCE=finance-events
KAFKA_TOPIC_IDENTITY=identity-events
KAFKA_USERNAME=
KAFKA_PASSWORD=

# Outbox polling parameters
OUTBOX_POLLING_INTERVAL_MS=500
OUTBOX_BATCH_SIZE=50

# VNPay Sandbox Configuration
VNPAY_TMN_CODE=DEMO2019
VNPAY_HASH_SECRET=SHA512SECRETKEYEXAMPLE
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=http://localhost:3000/payment-status
