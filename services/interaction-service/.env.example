# ===== Interaction Service (Rust) =====

# Server Configuration
SERVER_PORT=8080
GRPC_PORT=50051
APP_ENV=development
RUST_LOG=info,interaction_service=debug,tower_http=debug

# Database (PostgreSQL)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/interaction_service?sslmode=disable

# Kafka (Message Broker)
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC_INTERACTION=interaction-events
KAFKA_TOPIC_BOOKING=booking-events
KAFKA_GROUP_ID=interaction-service-group

# Outbox polling parameters
# Note: Thanks to the reactive Notify-driven polling pattern, this fallback polling interval
# can be safely increased to 5000ms to save DB CPU when idle, while still achieving instant 0-1ms latency.
OUTBOX_POLLING_INTERVAL_MS=5000
OUTBOX_BATCH_SIZE=50
