# Sample secret values for local development.
# Usage: Copy this file to values.secret.yaml, and customize it.
#   helm upgrade --install interaction-service ./deployments/helm \
#     -f ./deployments/helm/values.dev.yaml \
#     -f ./deployments/helm/values.secret.yaml

secrets:
  # Local PostgreSQL connection URL
  DATABASE_URL: "postgres://postgres:postgres@localhost:5432/interaction_service?sslmode=disable"
