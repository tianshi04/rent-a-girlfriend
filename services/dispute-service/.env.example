# ===== Dispute Resolution Service =====

# Server ports
SERVER_PORT=8082
GRPC_PORT=50051
APP_ENV=development

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=dispute_admin
DB_PASSWORD=super_secure_password
DB_NAME=dispute_service
DB_SSLMODE=disable

# Kafka (Message Broker)
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC_DISPUTE=dispute.events

# Outbox polling parameters
OUTBOX_POLLING_INTERVAL_MS=500
OUTBOX_BATCH_SIZE=50

# SAGA retry parameters
SAGA_RETRY_INTERVAL_SECONDS=5.0

# External Integrations (gRPC Clients / Mocks)
USE_MOCKS=true
FINANCE_SERVICE_ADDR=localhost:50052
INTERACTION_SERVICE_ADDR=localhost:50053

