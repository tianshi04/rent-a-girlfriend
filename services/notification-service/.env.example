# ===== Notification Service — Environment Variables =====
# Copy file này thành .env và điền giá trị thật

# ─── Server ──────────────────────────────────────────────────────────────────
SERVER_PORT=8080
SHUTDOWN_TIMEOUT=30s

# ─── Database (PostgreSQL) ────────────────────────────────────────────────────
# URL được lắp ghép trong application.yml:
#   jdbc:postgresql://${DB_HOST}:${DB_PORT}/${DB_NAME}${DB_OPTIONS}
DB_HOST=localhost
DB_PORT=5432
DB_NAME=notification_db
DB_USERNAME=postgres
DB_PASSWORD=

# Tùy chọn thêm vào cuối URL (ví dụ: ?sslmode=require&channelBinding=require)
DB_OPTIONS=

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ─── Kafka ───────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ─── SMTP (Mailtrap sandbox) ──────────────────────────────────────────────────
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USERNAME=
SMTP_PASSWORD=

# ─── Firebase ────────────────────────────────────────────────────────────────
FIREBASE_CONFIG_PATH=notification-service-d166c-firebase-adminsdk-fbsvc-4b6bc988c1.json

# ─── App ─────────────────────────────────────────────────────────────────────
TEMPLATES_PATH=classpath:templates.yaml
