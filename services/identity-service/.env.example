# ===== Identity Service =====

# Server
SERVER_PORT=8080
GRPC_PORT=50051
GIN_MODE=release

# Database (PostgreSQL)
DB_URL=postgres://identity_admin:super_secure_password@ep-hidden-sunset-a1b2c3.ap-southeast-1.aws.neon.tech/identity_service?sslmode=require

# Google OAuth
GOOGLE_CLIENT_ID=982374982374-example.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=gocsp_example_secret_key
GOOGLE_REDIRECT_URI=https://identity-service.up.railway.app/api/v1/auth/google/callback

# JWT
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=7
JWT_ISSUER=identity-service

# Kafka
KAFKA_BROKERS=kafka-1.upstash.io:9092,kafka-2.upstash.io:9092
KAFKA_TOPIC_IDENTITY=identity-events
KAFKA_USERNAME=upstash_user_example
KAFKA_PASSWORD=upstash_password_example

# Outbox
OUTBOX_POLLING_INTERVAL_MS=500
OUTBOX_BATCH_SIZE=50

# Redis (Upstash Redis)
REDIS_URL=rediss://default:example_password@ethical-grouse-12345.upstash.io:6379

# Features
ENABLE_TEST_ROUTES=false