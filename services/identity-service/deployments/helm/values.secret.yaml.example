# Copy this file to values.secret.yaml and fill in real values.
# values.secret.yaml is gitignored — NEVER commit it.
#
# Usage:
#   helm upgrade --install identity-service ./deployments/helm \
#     -f values.secret.yaml
#
# Or via CI/CD environment variables:
#   helm upgrade --install identity-service ./deployments/helm \
#     --set secrets.DB_URL=$DB_URL \
#     --set secrets.REDIS_URL=$REDIS_URL

secrets:
  DB_URL: ""              # postgres://user:password@host/db?sslmode=require
  GOOGLE_CLIENT_ID: ""    # Google OAuth client ID
  GOOGLE_CLIENT_SECRET: "" # Google OAuth client secret
  GOOGLE_REDIRECT_URI: ""  # Google OAuth callback URI
  REDIS_URL: ""           # rediss://default:password@host:port
