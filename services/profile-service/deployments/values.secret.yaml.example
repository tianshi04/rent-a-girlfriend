# Copy this file to values.secret.yaml and fill in real values.
# values.secret.yaml is gitignored — NEVER commit it.
#
# Usage:
#   helm upgrade --install profile-service ./deployments \
#     -f values.secret.yaml
#
# Or via CI/CD environment variables:
#   helm upgrade --install profile-service ./deployments \
#     --set secrets.DB_PASSWORD=$DB_PASSWORD

secrets:
  DB_PASSWORD: "super_secure_password"
  KAFKA_USERNAME: "kafka_user"
  KAFKA_PASSWORD: "kafka_password"
  S3_ACCESS_KEY_ID: "minio_admin"
  S3_SECRET_ACCESS_KEY: "minio_secure_password"