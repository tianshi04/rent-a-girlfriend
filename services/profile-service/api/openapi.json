    "/api/v1/profile/me/media/presigned-urls": {
      "post": {
        "tags": [
          "Media Management"
        ],
        "summary": "Request Presigned Url",
        "operationId": "request_presigned_url_api_v1_profile_me_media_presigned_urls_post",
        "parameters": [
          {
            "name": "user-id",
            "in": "header",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "User-Id"
            }
          },
          {
            "name": "user-role",
            "in": "header",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "User-Role"
            }
          },
          {
            "name": "user-status",
            "in": "header",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
