                },
                {
                  "type": "null"
                }
              ],
              "title": "User-Role"
            }
          },
          {
            "name": "user-status",
            "in": "header",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "User-Status"
            }
          },
          {
            "name": "user-email",
            "in": "header",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "User-Email"
            }
          }
