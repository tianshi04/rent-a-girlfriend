# ===== Profile & Catalogue Service =====

# Server ports
SERVER_PORT=8080
GRPC_PORT=50051
APP_ENV=development

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://profile_admin:super_secure_password@localhost:5432/profile_service

# S3-Compatible Object Storage (AWS S3, MinIO, R2, DO Spaces, etc.)
# Set S3_ENDPOINT_URL to bypass default AWS endpoints (e.g. http://localhost:9000 for MinIO local dev)
S3_ENDPOINT_URL=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minio_admin
S3_SECRET_ACCESS_KEY=minio_secure_password
S3_BUCKET_NAME=rentgf-media

# Kafka (Message Broker)
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC_PROFILE=profile.events
KAFKA_USERNAME=
KAFKA_PASSWORD=

# Outbox polling parameters
OUTBOX_POLLING_INTERVAL_MS=500
OUTBOX_BATCH_SIZE=50

# Database Cleanup Parameters
DB_CLEANUP_INTERVAL_MINUTES=30
OUTBOX_RETENTION_DAYS=1
