{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Rent-a-Girlfriend CloudEvents Schema",
  "description": "JSON Schema defining standard CloudEvents v1.0 envelope and domain-specific payloads.",
  "type": "object",
  "required": [
    "specversion",
    "id",
    "source",
    "type",
    "datacontenttype",
    "time",
    "data",
    "correlationid"
  ],
  "properties": {
    "specversion": {
      "type": "string",
      "enum": [
        "1.0"
      ]
    },
    "id": {
      "type": "string",
      "description": "Unique UUID for the event. Used for Consumer Idempotency check."
    },
    "source": {
      "type": "string",
      "description": "URI-reference identifying the context where event happened.",
      "example": "/rent-a-gf/booking-context/booking/bk_999"
    },
    "type": {
      "type": "string",
      "description": "Domain event type standard format: [domain].[event-name].[version]",
      "pattern": "^[a-z0-9\\-]+(\\.[a-z0-9\\-]+)+(\\.v[0-9]+)$"
    },
    "datacontenttype": {
      "type": "string",
      "enum": [
        "application/json"
      ]
    },
    "time": {
      "type": "string",
      "format": "date-time"
    },
    "correlationid": {
      "type": "string",
      "description": "Used for cross-service distributed tracing. Stored at root per CloudEvents JSON spec."
    },
    "data": {
      "type": "object",
      "description": "Domain-specific payload.",
      "oneOf": [
        {
          "$ref": "#/definitions/BookingRequestedPayload"
        },
        {
          "$ref": "#/definitions/BookingAcceptedPayload"
        },
        {
          "$ref": "#/definitions/BookingRejectedPayload"
        },
        {
          "$ref": "#/definitions/BookingCancelledEarlyPayload"
        },
        {
          "$ref": "#/definitions/BookingCancelledLatePayload"
        },
        {
          "$ref": "#/definitions/BookingTimedOutPayload"
        },
        {
          "$ref": "#/definitions/BookingCompletedPayload"
        },
        {
          "$ref": "#/definitions/CoinFrozenPayload"
        },
        {
          "$ref": "#/definitions/CoinsFreezeFailedPayload"
        },
        {
          "$ref": "#/definitions/CoinEscrowedPayload"
        },
        {
          "$ref": "#/definitions/EscrowFailedPayload"
        },
        {
          "$ref": "#/definitions/RefundFailedPayload"
        },
        {
          "$ref": "#/definitions/PayoutProcessedPayload"
        },
        {
          "$ref": "#/definitions/DisputeResolvedPayload"
        },
        {
          "$ref": "#/definitions/ChatRoomCreatedPayload"
        },
        {
          "$ref": "#/definitions/ReviewSubmittedPayload"
        },
        {
          "$ref": "#/definitions/ReportCreatedPayload"
        },
        {
          "$ref": "#/definitions/ViolationRecordedPayload"
        },
        {
          "$ref": "#/definitions/AccountLockedPayload"
        },
        {
          "$ref": "#/definitions/ProfileCreatedPayload"
        },
        {
          "$ref": "#/definitions/ProfileUpdatedPayload"
        },
        {
          "$ref": "#/definitions/ProfileApprovedPayload"
        },
        {
          "$ref": "#/definitions/ProfileRejectedPayload"
        },
        {
          "$ref": "#/definitions/ScenarioCreatedPayload"
        },
        {
          "$ref": "#/definitions/ScenarioUpdatedPayload"
        },
        {
          "$ref": "#/definitions/ScenarioDeletedPayload"
        },
        {
          "$ref": "#/definitions/VoiceIntroUploadedPayload"
        },
        {
          "$ref": "#/definitions/VoiceIntroRejectedPayload"
        },
        {
          "$ref": "#/definitions/AlbumImageUploadedPayload"
        }
      ]
    }
  },
  "definitions": {
    "BookingRequestedPayload": {
      "type": "object",
      "required": [
        "bookingId",
        "clientId",
        "companionId",
        "price",
        "startTime"
      ],
      "properties": {
        "bookingId": {
          "type": "string",
          "format": "uuid"
        },
        "clientId": {
          "type": "string",
          "format": "uuid"
        },
        "companionId": {
          "type": "string",
          "format": "uuid"
        },
        "price": {
          "type": "integer",
          "minimum": 1
        },
        "startTime": {
          "type": "string",
          "format": "date-time"
        },
        "sagaId": {
          "type": "string",
          "format": "uuid"
        }
      }
    },
    "BookingAcceptedPayload": {
      "type": "object",
      "required": [
        "bookingId",
        "clientId",
        "companionId",
        "price"
      ],
      "properties": {
        "bookingId": {
          "type": "string",
          "format": "uuid"
        },
        "clientId": {
          "type": "string",
          "format": "uuid"
        },
        "companionId": {
          "type": "string",
          "format": "uuid"
        },
        "price": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "BookingRejectedPayload": {
      "type": "object",
      "required": [
        "bookingId",
        "companionId",
        "clientId"
      ],
      "description": "Emitted by Booking Service. Finance Service listens to unfreeze Client coins.",
      "properties": {
        "bookingId": {
          "type": "string",
          "format": "uuid"
        },
        "companionId": {
          "type": "string",
          "format": "uuid"
        },
        "clientId": {
          "type": "string",
          "format": "uuid"
        },
        "reason": {
          "type": "string",
          "description": "Optional reason from companion."
        }
      }
    },
    "BookingCancelledEarlyPayload": {
      "type": "object",
      "required": [
        "bookingId",
        "actorId",
        "actorRole"
      ],
      "description": "Emitted when booking is cancelled >24h before startTime (BR-05, BR-07). Finance unfreeze/refund full.",
      "properties": {
        "bookingId": {
          "type": "string",
          "format": "uuid"
        },
        "actorId": {
          "type": "string",
          "format": "uuid"
        },
        "actorRole": {
          "type": "string",
          "enum": [
            "CLIENT",
            "COMPANION"
          ]
        }
      }
    },
    "BookingCancelledLatePayload": {
      "type": "object",
      "required": [
        "bookingId",
        "actorId",
        "actorRole"
      ],
      "description": "Emitted when booking is cancelled <24h before startTime (BR-06, BR-07a). Finance applies penalty logic.",
      "properties": {
        "bookingId": {
          "type": "string",
          "format": "uuid"
        },
        "actorId": {
          "type": "string",
          "format": "uuid"
        },
        "actorRole": {
          "type": "string",
          "enum": [
            "CLIENT",
            "COMPANION"
          ]
        }
      }
    },
    "BookingTimedOutPayload": {
      "type": "object",
      "required": [
        "bookingId",
        "clientId"
      ],
      "description": "Emitted by Booking Service scheduler when a PENDING booking exceeds 12h without companion response (BR-FR07). Finance Service listens to unfreeze coins.",
      "properties": {
        "bookingId": {
          "type": "string",
          "format": "uuid"
        },
        "clientId": {
          "type": "string",
          "format": "uuid"
        }
      }
    },
    "BookingCompletedPayload": {
      "type": "object",
      "required": [
        "bookingId",
        "companionId",
        "clientId",
        "price"
      ],
      "description": "Emitted by Booking Service scheduler at end_time+12h if no dispute exists (BR-16). Finance Service listens to execute Payout (BR-03).",
      "properties": {
        "bookingId": {
          "type": "string",
          "format": "uuid"
        },
        "companionId": {
          "type": "string",
          "format": "uuid"
        },
        "clientId": {
          "type": "string",
          "format": "uuid"
        },
        "price": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "CoinFrozenPayload": {
      "type": "object",
      "required": [
        "walletId",
        "amount",
        "refId"
      ],
      "properties": {
        "walletId": {
          "type": "string",
          "format": "uuid"
        },
        "amount": {
          "type": "integer"
        },
        "refId": {
          "type": "string",
          "format": "uuid",
          "description": "Associated booking ID"
        }
      }
    },
    "CoinEscrowedPayload": {
      "type": "object",
      "required": [
        "bookingId",
        "amount"
      ],
      "properties": {
        "bookingId": {
          "type": "string",
          "format": "uuid"
        },
        "amount": {
          "type": "integer"
        }
      }
    },
    "CoinsFreezeFailedPayload": {
      "type": "object",
      "required": [
        "bookingId",
        "userId",
        "amount",
        "reason"
      ],
      "description": "Emitted by Finance Service when coin freeze fails. Saga orchestrator listens to mark booking as failed.",
      "properties": {
        "bookingId": {
          "type": "string",
          "format": "uuid"
        },
        "userId": {
          "type": "string",
          "format": "uuid"
        },
        "amount": {
          "type": "integer"
        },
        "reason": {
          "type": "string",
          "description": "Technical failure reason."
        }
      }
    },
    "EscrowFailedPayload": {
      "type": "object",
      "required": [
        "bookingId",
        "clientId",
        "reason"
      ],
      "description": "Emitted by Finance Service when Escrow fails (SAGA compensating event). Booking Service listens to rollback booking status.",
      "properties": {
        "bookingId": {
          "type": "string",
          "format": "uuid"
        },
        "clientId": {
          "type": "string",
          "format": "uuid"
        },
        "reason": {
          "type": "string",
          "description": "Technical failure reason."
        }
      }
    },
    "RefundFailedPayload": {
      "type": "object",
      "required": [
        "bookingId",
        "clientId",
        "reason"
      ],
      "description": "Emitted by Finance Service when Escrow refund fails (SAGA compensating event). Booking Service listens to rollback/alert booking status.",
      "properties": {
        "bookingId": {
          "type": "string",
          "format": "uuid"
        },
        "clientId": {
          "type": "string",
          "format": "uuid"
        },
        "reason": {
          "type": "string",
          "description": "Technical failure reason."
        }
      }
    },
    "PayoutProcessedPayload": {
      "type": "object",
      "required": [
        "bookingId",
        "companionId",
        "payoutAmount",
        "commissionAmount"
      ],
      "properties": {
        "bookingId": {
          "type": "string",
          "format": "uuid"
        },
        "companionId": {
          "type": "string",
          "format": "uuid"
        },
        "payoutAmount": {
          "type": "integer",
          "description": "Net amount paid to companion (BR-03 commission deduction)."
        },
        "commissionAmount": {
          "type": "integer",
          "description": "Amount withheld by system."
        }
      }
    },
    "DisputeResolvedPayload": {
      "type": "object",
      "required": [
        "disputeId",
        "bookingId",
        "resolution",
        "resolvedBy",
        "reporterId",
        "accusedId"
      ],
      "description": "Emitted by Dispute Service when Admin resolves a dispute. Booking Service listens to finalize booking state. Finance Service listens for Payout or Refund.",
      "properties": {
        "disputeId": {
          "type": "string",
          "format": "uuid"
        },
        "bookingId": {
          "type": "string",
          "format": "uuid"
        },
        "resolvedBy": {
          "type": "string",
          "format": "uuid",
          "description": "Admin user ID."
        },
        "reporterId": {
          "type": "string",
          "format": "uuid"
        },
        "accusedId": {
          "type": "string",
          "format": "uuid"
        },
        "resolution": {
          "type": "string",
          "enum": [
            "PAYOUT_COMPANION",
            "REFUND_CLIENT",
            "REJECT"
          ],
          "description": "PAYOUT_COMPANION: booking → COMPLETED, review stays VISIBLE (BR-08b). REFUND_CLIENT: booking → CANCELLED, review → HIDDEN (BR-08a)."
        }
      }
    },
    "ChatRoomCreatedPayload": {
      "type": "object",
      "required": [
        "roomId",
        "bookingId",
        "clientUserId",
        "companionUserId"
      ],
      "properties": {
        "roomId": {
          "type": "string",
          "format": "uuid"
        },
        "bookingId": {
          "type": "string",
          "format": "uuid"
        },
        "clientUserId": {
          "type": "string",
          "format": "uuid"
        },
        "companionUserId": {
          "type": "string",
          "format": "uuid"
        }
      }
    },
    "ReviewSubmittedPayload": {
      "type": "object",
      "required": [
        "reviewId",
        "bookingId",
        "clientId",
        "companionId",
        "rating"
      ],
      "properties": {
        "reviewId": {
          "type": "string",
          "format": "uuid"
        },
        "bookingId": {
          "type": "string",
          "format": "uuid"
        },
        "clientId": {
          "type": "string",
          "format": "uuid"
        },
        "companionId": {
          "type": "string",
          "format": "uuid"
        },
        "rating": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5
        }
      }
    },
    "ReportCreatedPayload": {
      "type": "object",
      "required": [
        "disputeId",
        "bookingId",
        "reporterId",
        "reason"
      ],
      "properties": {
        "disputeId": {
          "type": "string",
          "format": "uuid"
        },
        "bookingId": {
          "type": "string",
          "format": "uuid"
        },
        "reporterId": {
          "type": "string",
          "format": "uuid"
        },
        "reason": {
          "type": "string",
          "enum": [
            "NO_SHOW",
            "MISCONDUCT"
          ]
        }
      }
    },
    "ViolationRecordedPayload": {
      "type": "object",
      "required": [
        "userId",
        "currentCount"
      ],
      "properties": {
        "userId": {
          "type": "string",
          "format": "uuid"
        },
        "currentCount": {
          "type": "integer",
          "description": "Current violation count before policy evaluation."
        }
      }
    },
    "AccountLockedPayload": {
      "type": "object",
      "required": [
        "userId",
        "reason"
      ],
      "properties": {
        "userId": {
          "type": "string",
          "format": "uuid"
        },
        "reason": {
          "type": "string",
          "example": "Exceeded maximum violation count."
        }
      }
    },
    "ProfileCreatedPayload": {
      "type": "object",
      "required": [
        "companionId",
        "userId",
        "displayName",
        "availableCities"
      ],
      "properties": {
        "companionId": {
          "type": "string",
          "format": "uuid"
        },
        "userId": {
          "type": "string",
          "format": "uuid"
        },
        "displayName": {
          "type": "string"
        },
        "availableCities": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "ProfileUpdatedPayload": {
      "type": "object",
      "required": [
        "companionId",
        "displayName",
        "availableCities"
      ],
      "properties": {
        "companionId": {
          "type": "string",
          "format": "uuid"
        },
        "displayName": {
          "type": "string"
        },
        "introText": {
          "type": "string"
        },
        "availableCities": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "ProfileApprovedPayload": {
      "type": "object",
      "required": [
        "companionId",
        "approvedBy"
      ],
      "properties": {
        "companionId": {
          "type": "string",
          "format": "uuid"
        },
        "approvedBy": {
          "type": "string",
          "format": "uuid"
        }
      }
    },
    "ProfileRejectedPayload": {
      "type": "object",
      "required": [
        "companionId",
        "rejectedBy",
        "reason"
      ],
      "properties": {
        "companionId": {
          "type": "string",
          "format": "uuid"
        },
        "rejectedBy": {
          "type": "string",
          "format": "uuid"
        },
        "reason": {
          "type": "string"
        }
      }
    },
    "ScenarioCreatedPayload": {
      "type": "object",
      "required": [
        "scenarioId",
        "companionId",
        "title",
        "price",
        "durationMinutes"
      ],
      "properties": {
        "scenarioId": {
          "type": "string",
          "format": "uuid"
        },
        "companionId": {
          "type": "string",
          "format": "uuid"
        },
        "title": {
          "type": "string"
        },
        "price": {
          "type": "integer",
          "minimum": 1
        },
        "durationMinutes": {
          "type": "integer",
          "enum": [
            60,
            120,
            180
          ]
        }
      }
    },
    "ScenarioUpdatedPayload": {
      "type": "object",
      "required": [
        "scenarioId",
        "companionId",
        "title",
        "price",
        "durationMinutes",
        "status"
      ],
      "properties": {
        "scenarioId": {
          "type": "string",
          "format": "uuid"
        },
        "companionId": {
          "type": "string",
          "format": "uuid"
        },
        "title": {
          "type": "string"
        },
        "price": {
          "type": "integer",
          "minimum": 1
        },
        "durationMinutes": {
          "type": "integer",
          "enum": [
            60,
            120,
            180
          ]
        },
        "status": {
          "type": "string",
          "enum": [
            "ACTIVE",
            "INACTIVE"
          ]
        }
      }
    },
    "ScenarioDeletedPayload": {
      "type": "object",
      "required": [
        "scenarioId",
        "companionId"
      ],
      "properties": {
        "scenarioId": {
          "type": "string",
          "format": "uuid"
        },
        "companionId": {
          "type": "string",
          "format": "uuid"
        }
      }
    },
    "VoiceIntroUploadedPayload": {
      "type": "object",
      "required": [
        "companionId",
        "assetId",
        "fileUrl",
        "durationSeconds",
        "sizeBytes"
      ],
      "properties": {
        "companionId": {
          "type": "string",
          "format": "uuid"
        },
        "assetId": {
          "type": "string",
          "format": "uuid"
        },
        "fileUrl": {
          "type": "string",
          "format": "uri"
        },
        "durationSeconds": {
          "type": "integer",
          "maximum": 30
        },
        "sizeBytes": {
          "type": "integer",
          "maximum": 5242880
        }
      }
    },
    "VoiceIntroRejectedPayload": {
      "type": "object",
      "required": [
        "companionId",
        "fileUrl",
        "reason"
      ],
      "properties": {
        "companionId": {
          "type": "string",
          "format": "uuid"
        },
        "fileUrl": {
          "type": "string",
          "format": "uri"
        },
        "reason": {
          "type": "string"
        }
      }
    },
    "AlbumImageUploadedPayload": {
      "type": "object",
      "required": [
        "companionId",
        "assetId",
        "fileUrl",
        "sizeBytes"
      ],
      "properties": {
        "companionId": {
          "type": "string",
          "format": "uuid"
        },
        "assetId": {
          "type": "string",
          "format": "uuid"
        },
        "fileUrl": {
          "type": "string",
          "format": "uri"
        },
        "sizeBytes": {
          "type": "integer",
          "maximum": 2097152
        }
      }
    }
  }
}